                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": "Attention(Q, K, V) = softmax(QK^T / √d_k) · V",
                                  "fontFamily": "IBM Plex Mono",
                                  "fontSize": 12,
                                  "fontWeight": "normal"
                                }
                              ]
                            },
                            {
                              "type": "text",
