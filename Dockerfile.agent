# ============================================================================
# Dockerfile.agent — Environment-only image for context-library
# ============================================================================
# Builds the ENVIRONMENT (tools + dependencies), NOT source code.
# Source code is mounted at runtime by the orchestrator.
# ============================================================================

# ============================================================================
# Section 1: Base Environment Setup
# ============================================================================
FROM clauditoreum-orchestrator:latest

# Base image includes: Claude CLI, Git, GitHub CLI, Python 3.11, build tools, procps

USER root

# ============================================================================
# Section 2: Install System Dependencies
# ============================================================================
# lancedb and sentence-transformers may need native build tools
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        build-essential \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# ============================================================================
# Section 3: Pre-install Python Dependencies
# ============================================================================
WORKDIR /workspace/context-library

# Copy project configuration for dependency installation
COPY pyproject.toml ./

# Create minimal package stub so hatchling can build during pip install
# (source code is mounted at runtime, not included in image)
RUN mkdir -p src/context_library && \
    touch src/context_library/__init__.py && \
    pip install --no-cache-dir ".[dev]" && \
    rm -rf src/context_library

# ============================================================================
# Section 4: Switch to Runtime User
# ============================================================================
USER orchestrator

# ============================================================================
# Section 5: Verification (MANDATORY)
# ============================================================================
RUN claude --version && \
    git --version && \
    gh --version && \
    python3 --version && \
    pip --version

# ============================================================================
# Default command
# ============================================================================
CMD ["/bin/bash"]
