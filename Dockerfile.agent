# ============================================================================
# Dockerfile.agent — Environment-only image for context-library
# ============================================================================
# Builds the ENVIRONMENT (tools + dependencies), NOT source code.
# Source code is mounted at runtime by the orchestrator.
# ============================================================================

# ============================================================================
# Stage 1: Base Environment Setup
# ============================================================================
FROM clauditoreum-orchestrator:latest

# Base image includes: Claude CLI, Git, GitHub CLI, Python 3.11, build tools, procps

USER root

# ============================================================================
# Stage 2: Install System Dependencies
# ============================================================================
# lancedb and sentence-transformers may need native build tools
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        build-essential \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# ============================================================================
# Stage 3: Pre-install Python Dependencies
# ============================================================================
WORKDIR /workspace/context-library

# Copy only pyproject.toml for dependency installation
COPY pyproject.toml ./

# Install project dependencies (runtime + dev) without the package itself
RUN pip install --no-cache-dir \
    "lancedb>=0.29" \
    "sentence-transformers>=5.0" \
    "mistune>=3.0" \
    "pydantic>=2.0" \
    ruff mypy pytest

# ============================================================================
# Stage 4: Switch to Runtime User
# ============================================================================
USER orchestrator

# ============================================================================
# Stage 5: Verification (MANDATORY)
# ============================================================================
RUN claude --version && \
    git --version && \
    gh --version && \
    python3 --version && \
    pip --version

# ============================================================================
# Default command
# ============================================================================
CMD ["/bin/bash"]
