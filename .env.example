# context-library server configuration
# Copy this file to .env and fill in your values.

# --- Authentication ---
# Bearer token required on all endpoints. Leave empty to disable auth.
CTX_WEBHOOK_SECRET=change-me

# --- context-helpers bridge ---
# URL of the context-helpers macOS bridge service.
# When running via Docker, use host.docker.internal instead of localhost.
CTX_HELPER_URL=http://host.docker.internal:7123
# Must match server.api_key in context-helpers config.yaml.
CTX_HELPER_API_KEY=change-me
# Opt-in to optional helper adapters.
CTX_HELPER_FILESYSTEM_ENABLED=false
CTX_HELPER_OBSIDIAN_ENABLED=false
CTX_HELPER_OURA_ENABLED=false

# --- Storage paths ---
# Defaults are suitable for Docker. Override for local runs.
CTX_SQLITE_DB_PATH=/data/sqlite/documents.db
CTX_CHROMADB_PATH=/data/chromadb

# --- Embedding model ---
# Any sentence-transformers model. Changing this requires a full re-embed.
CTX_EMBEDDING_MODEL=all-MiniLM-L6-v2

# --- Reranker (optional) ---
# Enable cross-encoder reranking on /query results.
CTX_ENABLE_RERANKER=false
CTX_RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# --- Server bind address ---
CTX_HOST=0.0.0.0
CTX_PORT=8000
